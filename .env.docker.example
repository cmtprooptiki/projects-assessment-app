# MySQL root password (used internally by Docker)
DB_ROOT_PASSWORD=change_me_root

# App database credentials
DB_NAME=projects_assessment
DB_USER=app_user
DB_PASSWORD=change_me_password

# JWT
JWT_SECRET=change_me_jwt_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# CORS — set to your frontend domain
CORS_ORIGIN=https://tracker.cmtprooptiki.gr

# Public URL of your backend
NEXT_PUBLIC_API_URL=https://api.tracker.cmtprooptiki.gr/api

# OpenAI (for AI assistant)
OPENAI_API_KEY=sk-your-key-here

# Read-only DB user for AI assistant (create with: GRANT SELECT ON db.* TO 'assistant_ro'@'%')
DB_RO_USERNAME=assistant_ro
DB_RO_PASSWORD=change_me_ro_password
