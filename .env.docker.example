# MySQL root password (used internally by Docker)
DB_ROOT_PASSWORD=change_me_root

# App database credentials
DB_NAME=projects_assessment
DB_USER=app_user
DB_PASSWORD=change_me_password

# JWT
JWT_SECRET=change_me_jwt_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Public URL of your backend — set this to your server's IP or domain
# e.g. http://123.45.67.89:3001/api  or  https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3001/api
